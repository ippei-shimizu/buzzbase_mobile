# API
EXPO_PUBLIC_API_URL=http://localhost:3100
EXPO_PUBLIC_APP_ENV=development

# Confirm URL (devise_token_auth)
EXPO_PUBLIC_CONFIRM_SUCCESS_URL=buzzbase://confirmation-success

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# RevenueCat (Pro subscription via App Store / Google Play)
# 値は RevenueCat ダッシュボード > Project > API keys > App-specific keys から取得。
# CI / EAS Build では EAS Secret 経由で参照する: `eas secret:create --scope project --name EXPO_PUBLIC_REVENUECAT_API_KEY_IOS --value appl_xxx`
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
